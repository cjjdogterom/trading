# Kopieer naar .env en vul je eigen Alpaca keys in.
# Paper keys beginnen met PK..., live keys met AK...
ALPACA_API_KEY=your_key_id_here
ALPACA_SECRET_KEY=your_secret_key_here

# true = paper (oefengeld), false = live (echt geld)
ALPACA_PAPER=true

# iex (gratis) of sip (betaald abonnement)
ALPACA_DATA_FEED=iex
